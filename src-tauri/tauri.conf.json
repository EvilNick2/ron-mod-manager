{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RoN Mod Manager",
  "version": "0.2.2",
  "identifier": "com.EvilNick.ron-mod-manager",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "RoN Mod Manager",
        "width": 1400,
        "height": 800,
        "minWidth": 900,
        "minHeight": 650,
        "resizable": true,
        "fullscreen": false,
        "maximized": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": [
      "msi",
      "dmg",
      "appimage",
      "deb",
      "rpm"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg0NTc5QTIzOUREN0U1QjQKUldTMDVkZWRJNXBYaEhxQlBIY0MyeDMzL1ZkUlZIajhYN3lKV0gvL1NiU1VwTjNzT0lKelRNb3oK",
      "endpoints": [
        "https://evilnick2.github.io/ron-mod-manager/latest.json"
      ]
    }
  }
}
